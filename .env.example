# Public browser config
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_APP_URL=https://floom.dev
NEXT_PUBLIC_FLOOM_ORIGIN=https://floom.dev

# Server-only Supabase and Floom runtime config
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
AGENT_TOKEN_PEPPER=replace-with-a-random-server-only-pepper
FLOOM_SECRET_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key
FLOOM_ORIGIN=https://floom.dev

# E2B runtime
E2B_API_KEY=your-e2b-api-key

# Async execution runtime
FLOOM_ASYNC_RUNTIME=disabled
FLOOM_WORKER_URL=https://your-preview-or-production-url
QSTASH_TOKEN=your-upstash-qstash-token
QSTASH_CURRENT_SIGNING_KEY=your-current-qstash-signing-key
QSTASH_NEXT_SIGNING_KEY=your-next-qstash-signing-key
FLOOM_EXECUTION_LEASE_MS=90000
FLOOM_APP_CONCURRENCY_SOFT_LIMIT=10
FLOOM_APP_QUEUE_MAX=100
# Transactional email via Resend (https://resend.com)
# Required in Production. When unset, emails are logged to stdout instead.
# Sender domain: send.floom.dev (DKIM + SPF already configured on this subdomain).
# DNS records needed (add via IONOS):
#   TXT  send.floom.dev             "v=spf1 include:amazonses.com ~all"
#   TXT  resend._domainkey.send.floom.dev  <value from Resend dashboard>
#   TXT  _dmarc.send.floom.dev      "v=DMARC1; p=quarantine; rua=mailto:hello@floom.dev"
RESEND_API_KEY=
# Override the From address (optional — defaults to "Floom <team@send.floom.dev>")
RESEND_FROM=

# Optional Sentry monitoring
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
